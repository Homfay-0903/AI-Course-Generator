# NeonDB serverless PostgreSQL connection string.
# Create a free database at https://neon.tech
# Copy the connection string from the Neon dashboard.
# Use the "Pooled connection" variant for the neon-http driver.
# Format: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Clerk authentication publishable key.
# Create an account at https://clerk.com, set up an application,
# and copy the Publishable Key from the Clerk Dashboard.
# Must be prefixed with EXPO_PUBLIC_ so it's available in the client bundle.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
